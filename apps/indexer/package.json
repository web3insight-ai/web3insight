{
  "name": "@web3insight/indexer",
  "private": true,
  "version": "0.1.0",
  "description": "GHArchive ingestion to PostgreSQL data warehouse (Rust + tokio + sqlx). Populates the data.* schema consumed by @web3insight/api.",
  "scripts": {
    "build": "cargo build --release",
    "start": "cargo run --release",
    "test": "cargo test --all",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings",
    "lint:fix": "cargo clippy --all-targets --all-features --fix --allow-dirty --allow-staged -- -D warnings",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "typecheck": "cargo check --all-targets --all-features",
    "clean": "cargo clean"
  }
}
