    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "25.8.0",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "@types/supertest": "^7.2.0",
    "@web3insight/eslint-config": "workspace:*",
    "@web3insight/typescript-config": "workspace:*",
    "dotenv": "^17.4.2",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "kysely-codegen": "^0.20.0",
