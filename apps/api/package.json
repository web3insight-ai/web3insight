    "ai": "catalog:",
    "hono": "catalog:",
    "@hono/zod-validator": "catalog:",
    "inngest": "catalog:",
    "jose": "catalog:",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "fp-ts": "^2.16.11",
    "kysely": "catalog:",
    "nestjs-console": "^10.0.0",
    "pg": "catalog:",
    "pg-cursor": "^2.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
