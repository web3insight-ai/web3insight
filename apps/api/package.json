    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "^11.4.3",
    "@octokit/rest": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@privy-io/node": "^0.18.0",
